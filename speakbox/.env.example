# Speakbox 服务端环境变量模板
# 实际文件部署在服务器 /opt/speakbox/.env（不进 git，见 .gitignore）。
# 本模板可入库：只放占位值，绝不写真实 WORKER_TOKEN。

# 监听地址。默认 :8200；若 8200 被占用改 :8201（见 DEPLOY.md «端口确认»）。
ADDRESS=:8200

# 数据根目录。WAV 落盘到 <DATA_DIR>/wav/<id>.wav。
DATA_DIR=/data/speakbox

# Worker 共享密钥：保护 /api/worker/* 端点（worker 请求头 X-Worker-Token 必须等于此值）。
# 空值 => 所有 worker 端点返回 401（服务起得来，但没人能消费任务）。
# 用 `openssl rand -hex 32` 生成，写进服务器 /opt/speakbox/.env，
# 同一个值再喂给 Mac 上的常驻 worker。⚠ 真实值只留服务器，永不进 git / 文档。
WORKER_TOKEN=REPLACE_WITH_openssl_rand_hex_32
